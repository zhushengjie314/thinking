{
  "name": "data-cleaning-platform",
  "version": "1.0.0",
  "description": "Visual Data Cleaning Platform - 可视化数据清洗平台",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install"
  },
  "keywords": [
    "data-cleaning",
    "visualization",
    "csv",
    "excel",
    "analytics"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "concurrently": "^9.2.0",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "csv-writer": "^1.6.0",
    "express": "^5.1.0",
    "lodash": "^4.17.21",
    "multer": "^2.0.2",
    "nodemon": "^3.1.10",
    "xlsx": "^0.18.5"
  }
}
